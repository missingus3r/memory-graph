#!/usr/bin/env bash
# Auto-sync README version with VERSION constant in api_server.py

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
API="$REPO_ROOT/api_server.py"
README="$REPO_ROOT/README.md"

[ -f "$API" ] && [ -f "$README" ] || exit 0

VERSION=$(grep -E '^VERSION\s*=\s*"' "$API" | head -1 | sed -E 's/^VERSION\s*=\s*"([^"]+)".*/\1/')
[ -z "$VERSION" ] && exit 0

CURRENT=$(grep -oE '\*\*Version:\*\* [0-9]+\.[0-9]+\.[0-9]+' "$README" | head -1 | awk '{print $2}')

if [ "$VERSION" != "$CURRENT" ]; then
    sed -i -E "s/\*\*Version:\*\* [0-9]+\.[0-9]+\.[0-9]+/**Version:** $VERSION/" "$README"
    git add "$README"
    echo "[pre-commit] README version synced to $VERSION"
fi

exit 0
